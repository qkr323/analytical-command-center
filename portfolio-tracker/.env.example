# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://portfolio:portfolio@db:5432/portfolio

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Anthropic (Claude Vision — PDF parsing) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── IBKR Flex Web Service ─────────────────────────────────────────────────────
# Get from: IBKR Account Management → Reports → Flex Queries
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

# ── Futu OpenD ────────────────────────────────────────────────────────────────
# Must be running locally (GUI) or as a daemon (CLI)
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
# MD5 of your Futu trading PIN — run: echo -n "YOUR_PIN" | md5
FUTU_TRADE_PASSWORD_MD5=

# ── Binance ───────────────────────────────────────────────────────────────────
# Create a read-only API key at Binance → Account → API Management
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# ── Alpaca (US stock live prices — free tier) ─────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_64_char_hex_string
# API key required on every request (set in production; leave blank for local dev)
API_SECRET=change_this_to_a_random_64_char_hex_string
ENVIRONMENT=development
BASE_CURRENCY=HKD
# Full URL of your deployed frontend (e.g. https://your-app.vercel.app)
FRONTEND_URL=
